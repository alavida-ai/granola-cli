{
  "name": "granola-plugin",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript monorepo for the Alavida Granola plugin — CLI + OpenClaw + Claude Code skill for reading Granola.ai notes.",
  "license": "UNLICENSED",
  "homepage": "https://github.com/alavida-ai/granola-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/alavida-ai/granola-plugin.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "preinstall": "node scripts/check-pnpm.mjs",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20.16.10",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
